<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="400.0"
            style="-fx-background-image: url('/images/wallpaper.jpg'); -fx-background-size: cover; -fx-background-position: center; -fx-background-repeat: no-repeat;"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="mortis.MainWindow">
    <children>
        <TextField fx:id="userInput" layoutY="558.0" onAction="#handleUserInput" prefHeight="41.0" prefWidth="324.0"
                   promptText="Enter command here..." style="-fx-background-color: F0DDC8;"
                   AnchorPane.bottomAnchor="1.0">
            <font>
                <Font name="System Italic" size="12.0"/>
            </font>
        </TextField>
        <Button fx:id="sendButton" layoutX="324.0" layoutY="558.0" mnemonicParsing="false" onAction="#handleUserInput"
                prefHeight="41.0" prefWidth="76.0" style="-fx-background-color: D1AB9A;" text="SEND">
            <font>
                <Font name="Franklin Gothic Medium Cond" size="16.0"/>
            </font>
        </Button>

        <ScrollPane fx:id="scrollPane" hbarPolicy="NEVER" hvalue="1.0" prefHeight="557.0" prefWidth="400.0" vvalue="1.0"
                    style="-fx-background-color: transparent;">
            <content>
                <VBox fx:id="dialogContainer" prefHeight="552.0" prefWidth="400.0"
                      style="-fx-background-color: transparent;"/>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
